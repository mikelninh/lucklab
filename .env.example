# ===========================================================
# Kairos Lab — Environment Variables
# Copy this file to .env.local for local dev.
# Set all of these in Vercel → Project Settings → Environment.
# ===========================================================

# --- App ---
# Public URL of the deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- OpenAI (Tyche's brain) ---
# Used by /api/tyche/read and /reading/full to generate the readings.
# Without it, the app uses deterministic fallback copy.
OPENAI_API_KEY=sk-proj-…

# --- Stripe (checkout for Tyche's Reading, €29) ---
# Test keys in development, live keys in production.
STRIPE_SECRET_KEY=sk_test_…
# Optional — only needed if you re-enable the webhook handler later.
STRIPE_WEBHOOK_SECRET=whsec_…

# --- Resend (email delivery) ---
# Used for Convergence Index PDF delivery after email capture.
RESEND_API_KEY=re_…
EMAIL_FROM="Kairos Lab <hallo@kairos.lab>"
